<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>StemForge 0.0.1</title>
    <organization>com.stemforge</organization>
    <options allow-external-scripts="no" hostArchitectures="x86_64,arm64" customize="never" require-scripts="false" rootVolumeOnly="true"/>
    <domains enable_localSystem="true" enable_currentUserHome="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="12.0"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default">
            <line choice="com.stemforge.system"/>
            <line choice="com.stemforge.user"/>
        </line>
    </choices-outline>
    <choice id="default" title="StemForge"/>
    <choice id="com.stemforge.system" title="StemForge Native Binary" description="Installs stemforge-native and ONNX Runtime to /usr/local." enabled="false" selected="true">
        <pkg-ref id="com.stemforge.system"/>
    </choice>
    <choice id="com.stemforge.user" title="Ableton Integration" description="Installs the Max for Live device and template into your Ableton User Library." enabled="false" selected="true">
        <pkg-ref id="com.stemforge.user"/>
    </choice>
    <pkg-ref id="com.stemforge.system" version="0.0.1" onConclusion="none">system.pkg</pkg-ref>
    <pkg-ref id="com.stemforge.user" version="0.0.1" onConclusion="none">user.pkg</pkg-ref>
</installer-gui-script>
